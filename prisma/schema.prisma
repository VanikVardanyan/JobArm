generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Task {
  id           String   @id @default(uuid())
  description  String
  budget       Int?
  phone        String
  manageToken  String   @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime
}
